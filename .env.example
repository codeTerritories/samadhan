# ── Samadhan — Environment Variables Example ──────────────────
# Copy this file to .env and fill in values as needed.
# .env is git-ignored — never commit real secrets.

# Base URL for the app (used by Vite at build time)
# Leave blank for root deployment. Use '/samadhan/' for GitHub Pages sub-path.
# VITE_BASE_URL=/

# Analytics (optional — add your own tracking ID if needed)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Contact form backend (optional — if you wire up a real form endpoint)
# VITE_FORM_ENDPOINT=https://your-form-handler.example.com/submit
